# Copy to .env and adjust for your environment

# --- Django
APP_VERSION=V5.2.29
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com

CSRF_COOKIE_SECURE=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SAMESITE=Lax

# --- Postgres
POSTGRES_DB=stockalert
POSTGRES_USER=stockalert
POSTGRES_PASSWORD=stockalert
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery
REDIS_URL=redis://redis:6379/0

# --- Twelve Data
TWELVE_DATA_API_KEY=
DEFAULT_EXCHANGE=

# --- Scheduler hours (server local time)
FETCH_BARS_HOUR=1
COMPUTE_HOUR=2
EMAIL_HOUR=7

# --- Email (alerts)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_FROM=alerts@example.com

# --- Parquet storage (Step 1/2)
ENABLE_PARQUET_STORAGE=1
BACKTEST_DATA_DIR=/data

# --- Volume guards (Step 3)
ENABLE_VOLUME_GUARDS=1
EXCEL_FULL_TICKERS_THRESHOLD=150
EXCEL_TOP_N=50


# Daily batch schedule (local time: APP_TIMEZONE)
DAILY_REFRESH_HOUR=8
DAILY_REFRESH_MINUTE=0

# Gunicorn runtime hardening
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=20
GUNICORN_MAX_REQUESTS_JITTER=10
GUNICORN_LOG_LEVEL=info

TWELVEDATA_RATE_LIMIT_ENABLED=1
TWELVEDATA_MAX_CALLS_PER_MINUTE=340
TWELVEDATA_RATE_LIMIT_WINDOW_SECONDS=60
TWELVEDATA_RATE_LIMIT_SLEEP_BUFFER_SECONDS=0.25
TWELVEDATA_BACKOFF_SECONDS=65
TWELVEDATA_MAX_RETRIES=3


# --- DB admin UI
# Adminer is exposed on http://localhost:8081 in local docker-compose

CELERY_TASK_ACKS_LATE=0
CELERY_TASK_REJECT_ON_WORKER_LOST=0
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_CONCURRENCY=1
CELERY_TASK_TRACK_STARTED=1
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=1
JOB_RECOVER_ORPHANED_ON_WORKER_READY=1
JOB_FULL_RECOMPUTE_INSTRUMENTATION=1
JOB_FULL_RECOMPUTE_LOG_EVERY_N_SYMBOLS=1
JOB_FULL_RECOMPUTE_LOG_EVERY_N_DATES=200