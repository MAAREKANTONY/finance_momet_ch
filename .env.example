# Copy to .env and adjust for your environment

# --- Django
APP_VERSION=V5.2.29
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
DJANGO_TEST_USE_SQLITE=1
APP_TIMEZONE=UTC

CSRF_COOKIE_SECURE=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SAMESITE=Lax

# --- Postgres
POSTGRES_DB=stockalert
POSTGRES_USER=stockalert
POSTGRES_PASSWORD=stockalert
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery
REDIS_URL=redis://redis:6379/0

# --- Twelve Data
TWELVE_DATA_API_KEY=
DEFAULT_EXCHANGE=

# --- EODHD
EODHD_API_KEY=
EODHD_BASE_URL=https://eodhd.com/api
EODHD_REQUEST_DELAY_SECONDS=0
EODHD_MAX_RETRIES=3
EODHD_BACKOFF_SECONDS=1
EODHD_MARKET_CAP_SYNC_START_DATE=2020-01-01

# --- Scheduler hours (server local time)
FETCH_BARS_HOUR=1
COMPUTE_HOUR=2
EMAIL_HOUR=7
GAME_SCENARIO_RUN_HOUR=3
GAME_SCENARIO_RUN_MINUTE=5

# --- Email (alerts)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_FROM=alerts@example.com

# --- Parquet storage (Step 1/2)
ENABLE_PARQUET_STORAGE=1
BACKTEST_DATA_DIR=/data

# --- Volume guards (Step 3)
ENABLE_VOLUME_GUARDS=1
EXCEL_FULL_TICKERS_THRESHOLD=150
EXCEL_TOP_N=50


# Daily batch schedule (local time: APP_TIMEZONE)
DAILY_REFRESH_HOUR=8
DAILY_REFRESH_MINUTE=0
ENABLE_DAILY_BENCHMARK_ETF_SYNC=1

# Gunicorn runtime hardening
GUNICORN_BIND=0.0.0.0:8000
WEB_CONCURRENCY=1
GUNICORN_WORKER_CLASS=sync
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=20
GUNICORN_MAX_REQUESTS_JITTER=10
GUNICORN_LOG_LEVEL=info
GUNICORN_WORKER_TMP_DIR=/dev/shm

TWELVEDATA_RATE_LIMIT_ENABLED=1
TWELVEDATA_MAX_CALLS_PER_MINUTE=340
TWELVEDATA_RATE_LIMIT_WINDOW_SECONDS=60
TWELVEDATA_RATE_LIMIT_SLEEP_BUFFER_SECONDS=0.25
TWELVEDATA_RATE_LIMIT_KEY_PREFIX=ratelimit:twelvedata
TWELVEDATA_BACKOFF_SECONDS=65
TWELVEDATA_MAX_RETRIES=3

# --- Backtest/offload controls
BACKTEST_RESULTS_MAX_DB_MB=200

# --- Job recovery / retries
JOB_DB_RETRY_ATTEMPTS=5
JOB_DB_RETRY_DELAY_SECONDS=2
JOB_DB_RETRY_BACKOFF_SECONDS=2
JOB_TASK_RETRY_COUNTDOWN_SECONDS=15
JOB_TASK_MAX_RETRIES=5
JOB_STALE_HEARTBEAT_MINUTES=2
JOB_STALE_STARTED_MINUTES=3
JOB_STALE_PENDING_MINUTES=10
JOB_REQUESTED_STOP_STALE_MINUTES=1

# --- Diagnostics
REQUEST_MEMORY_LOG_LEVEL=INFO

# --- Docker Compose
COMPOSE_PROJECT_NAME=stockalert

# --- DB admin UI
# Adminer is exposed on http://localhost:8081 in local docker-compose
